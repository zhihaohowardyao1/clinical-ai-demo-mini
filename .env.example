# Safe server-side runtime defaults for a public demo.
# Do not put real secrets in this file.

# Optional server binding overrides for deployment platforms.
HOST=0.0.0.0
PORT=3000

# Optional DuckDB runtime overrides.
DUCKDB_PATH=db/clinical_demo.duckdb
DUCKDB_PYTHON_BIN=python3

# auto = use live mode when fully configured, otherwise stay in mock mode
# mock = always use mock mode
# live = try live mode first
MODEL_PROVIDER=auto

# openai_compatible = OpenAI-compatible chat/responses endpoint
# generic_json = generic JSON endpoint using the same structured contract
LIVE_PROVIDER_KIND=openai_compatible

# Live provider endpoint and model
LLM_API_URL=
LLM_MODEL=gpt-4.1-mini

# Server-side only secret
LLM_API_KEY=

# Runtime behavior
LLM_MAX_RETRIES=2
LLM_TIMEOUT_MS=15000
LLM_FALLBACK_TO_MOCK=true
